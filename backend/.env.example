# Copy this file to .env and fill in real values. Never commit .env.

APP_NAME=Audit Trail Q&A System
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# PostgreSQL connection (SQLAlchemy URL)
DATABASE_URL=postgresql+psycopg2://audit_user:changeme@localhost:5432/audit_trail_db

# JWT auth. Generate a real secret with: python -c "import secrets; print(secrets.token_hex(32))"
# Never reuse this placeholder value.
JWT_SECRET_KEY=changeme-generate-a-64-char-hex-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of allowed frontend origins
BACKEND_CORS_ORIGINS=http://localhost:3000

# Rule engine (Phase 7)
THRESHOLD_VIOLATION_AMOUNT=10000.00
DUPLICATE_DETECTION_WINDOW_HOURS=24
